# .env.sample
# Copy to .env (git-ignored) and fill in real values.

# ── Kamal deployment ───────────────────────────────────────────────────────────
# Domain the app is served at (SSL cert is issued for this domain).
APP_DOMAIN=small-llm.example.com

# Target server IP address (must allow SSH from the machine running `task deploy`)
WEB_SERVER_IP=1.2.3.4

# Container registry
REGISTRY_SERVER=registry.gitlab.com
REGISTRY_USERNAME=your-username

# ── Frontend (Vite dev server) ─────────────────────────────────────────────────
# Override the Go API URL during local development if needed.
# Leave empty to use the default proxy (http://localhost:8080).
# VITE_API_URL=http://localhost:8080
